{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "OpenSession Desktop",
	"version": "0.2.34",
	"identifier": "io.opensession.desktop",
	"build": {
		"beforeDevCommand": "npm --prefix ../web run dev -- --host 127.0.0.1 --port 5173",
		"beforeBuildCommand": "npm --prefix ../web run build",
		"devUrl": "http://127.0.0.1:5173",
		"frontendDist": "../../web/build"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"label": "main",
				"title": "OpenSession Desktop",
				"width": 1360,
				"height": 900,
				"minWidth": 1024,
				"minHeight": 700
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all"
	}
}
